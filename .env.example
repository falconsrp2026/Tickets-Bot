DISCORD_TOKEN=your_discord_bot_token_here
MONGO_URI=mongodb://127.0.0.1:27017/tickets-bot

# Web dashboard
PORT=3000
HOST=0.0.0.0

# Protect /api routes. If set, the dashboard requires this token in requests.
# Send as: Authorization: Bearer <token>
DASHBOARD_TOKEN=change_me_to_a_long_random_value

# Optional: restrict CORS (example: http://localhost:3000)
# CORS_ORIGIN=

# Bot settings
PREFIX=-

# Anti-spam: minimum time between opening tickets (milliseconds)
TICKET_OPEN_COOLDOWN_MS=10000

